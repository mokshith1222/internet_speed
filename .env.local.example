# Google AdSense Configuration
# Replace YOUR_ADSENSE_ID with your actual Google AdSense Publisher ID
# Example: ca-pub-1234567890123456
NEXT_PUBLIC_ADSENSE_ID=ca-pub-YOUR_ADSENSE_ID

# Google Search Console
# Your site verification code from Google Search Console
NEXT_PUBLIC_GSC_VERIFICATION=googlefbfa23743896d7f7

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=G_YOUR_GOOGLE_ANALYTICS_ID
